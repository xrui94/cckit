@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies
if(@CCKIT_BUILD_MATH@)
    find_dependency(glm CONFIG REQUIRED)
endif()

if(@CCKIT_BUILD_LOGGING@)
    find_dependency(spdlog CONFIG REQUIRED)
endif()

if(@CCKIT_BUILD_UUID@)
    find_dependency(Boost REQUIRED COMPONENTS uuid)
endif()

if(@CCKIT_USE_GHC_FS@)
    find_dependency(ghc_filesystem CONFIG REQUIRED)
endif()

# Include all module targets
# Note: cckit::cckit is already defined in cckitTargets.cmake
include("${CMAKE_CURRENT_LIST_DIR}/cckitTargets.cmake")

check_required_components(cckit)
